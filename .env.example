PORT=3333
DATABASE_URL="postgresql://user:password@localhost:5432/api_barleys?schema=public"

# Only used by docker-compose.yml to set up the Postgres container
POSTGRES_PASSWORD=change-me-db

# API key required by clients calling this server (Authorization: Bearer <API_KEY>)
API_KEY=change-me

# CRM webhook (Baileys -> Lovable/CRM)
WEBHOOK_URL=https://dashboard.agenciaunix.com/api/public/whatsapp-webhook
# Must match the CRM's WHATSAPP_WEBHOOK_SECRET so X-Signature verifies on their side
WEBHOOK_SECRET=change-me-too
